generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Application {
  id                 String                     @id @default(cuid())
  applicationNo      String                     @unique
  name               String
  phone              String
  email              String
  address            String
  facebookName       String
  facebookProfileUrl String
  planId             String
  plan               MembershipPlan             @relation(fields: [planId], references: [id])
  status             ApplicationStatus          @default(PENDING_PAYMENT)
  agreedToTermsAt    DateTime
  approvedAt         DateTime?
  joinedFacebookAt   DateTime?
  rejectedAt         DateTime?
  cancelledAt        DateTime?
  paymentReports     PaymentReport[]
  emailLogs          EmailLog[]
  statusHistory      ApplicationStatusHistory[]
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  @@index([status, createdAt])
  @@index([email])
  @@index([phone])
  @@index([planId])
}

model MembershipPlan {
  id           String        @id @default(cuid())
  code         String        @unique
  name         String
  price        Int
  durationDays Int
  description  String?
  benefits     Json?
  isActive     Boolean       @default(true)
  sortOrder    Int           @default(0)
  applications Application[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([isActive, sortOrder])
}

model PaymentReport {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  amount        Int
  bankLast5     String
  payerName     String
  paidAt        DateTime
  screenshotUrl String?
  note          String?
  reviewedAt    DateTime?
  reviewedById  String?
  reviewedBy    AdminUser?  @relation(fields: [reviewedById], references: [id], onDelete: SetNull)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([applicationId, createdAt])
  @@index([bankLast5])
  @@index([reviewedById])
}

model EmailLog {
  id            String       @id @default(cuid())
  applicationId String?
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  type          EmailType
  recipient     String
  subject       String
  status        EmailStatus  @default(PENDING)
  providerId    String?
  errorMessage  String?
  sentAt        DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([applicationId, createdAt])
  @@index([status, createdAt])
  @@index([recipient])
}

model AdminUser {
  id               String                     @id @default(cuid())
  email            String                     @unique
  passwordHash     String
  name             String
  isActive         Boolean                    @default(true)
  lastLoginAt      DateTime?
  sessions         AdminSession[]
  reviewedPayments PaymentReport[]
  statusChanges    ApplicationStatusHistory[]
  updatedSettings  SystemSetting[]
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
}

model SystemSetting {
  key         String     @id
  value       String
  description String?
  updatedById String?
  updatedBy   AdminUser? @relation(fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([updatedById])
}

model AdminSession {
  id          String    @id @default(cuid())
  tokenHash   String    @unique
  adminUserId String
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@index([adminUserId])
  @@index([expiresAt])
}

model ApplicationStatusHistory {
  id            String             @id @default(cuid())
  applicationId String
  application   Application        @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  fromStatus    ApplicationStatus?
  toStatus      ApplicationStatus
  note          String?
  changedById   String?
  changedBy     AdminUser?         @relation(fields: [changedById], references: [id], onDelete: SetNull)
  createdAt     DateTime           @default(now())

  @@index([applicationId, createdAt])
  @@index([changedById])
}

model Course {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  subtitle        String?
  category        String
  excerpt         String
  description     String
  outline         Json?
  audiences       Json?
  lessonCount     Int       @default(0)
  durationText    String?
  coverImageUrl   String?
  previewVideoUrl String?
  isPublished     Boolean   @default(false)
  isFeatured      Boolean   @default(false)
  sortOrder       Int       @default(0)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([isPublished, sortOrder])
  @@index([category])
}

model ContactMessage {
  id        String               @id @default(cuid())
  name      String
  email     String
  phone     String?
  type      ContactMessageType
  content   String
  status    ContactMessageStatus @default(NEW)
  repliedAt DateTime?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([status, createdAt])
  @@index([email])
}

enum ApplicationStatus {
  PENDING_PAYMENT
  PAYMENT_REPORTED
  APPROVED
  JOINED_FACEBOOK_GROUP
  REJECTED
  CANCELLED
}

enum EmailType {
  APPLICATION_CREATED
  PAYMENT_REPORTED_USER
  PAYMENT_REPORTED_ADMIN
  APPLICATION_APPROVED
  FACEBOOK_GROUP_JOINED
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

enum ContactMessageType {
  APPLICATION
  PAYMENT
  COURSE
  EVENT
  OTHER
}

enum ContactMessageStatus {
  NEW
  PROCESSING
  REPLIED
  CLOSED
}
