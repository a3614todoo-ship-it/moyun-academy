# Supabase 雲端 PostgreSQL
# 網站執行與 Vercel Serverless 使用 Transaction pooler（通常為 6543）
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@REGION.pooler.supabase.com:6543/postgres?sslmode=require"

# Prisma migration 使用 Direct connection；若本機網路不支援 IPv6，
# 可改用 Supavisor Session pooler（通常為 5432）
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# 首位管理員；執行 npm run db:seed 時建立
ADMIN_EMAIL="admin@example.com"
ADMIN_INITIAL_PASSWORD="請改成至少 12 字元的安全密碼"
ADMIN_NAME="我輩學堂管理員"

# 後續 Email 與網站設定
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
EMAIL_PROVIDER=""
RESEND_API_KEY=""
EMAIL_FROM=""
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASSWORD=""
# 後台尚未設定時使用的備援值
FACEBOOK_GROUP_URL=""

# 匯款資訊（後台尚未設定時使用的備援值）
BANK_NAME=""
BANK_BRANCH=""
BANK_ACCOUNT_NAME=""
BANK_ACCOUNT_NUMBER=""
