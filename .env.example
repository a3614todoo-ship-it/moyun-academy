# PostgreSQL 執行期連線（建議使用連線池，且強制 sslmode=require）
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/DATABASE?sslmode=require"

# Supabase Server root certificate 的 PEM 內容經 Base64 編碼後填入；設定後會強制驗證憑證與主機名稱。
DATABASE_CA_CERT_BASE64=""

# Prisma migration 專用直連；不要讓網站執行期帳號擁有 migration 權限
DIRECT_URL="postgresql://MIGRATION_USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# 僅供首次建立管理員；帳號存在時 seed 不會再重設密碼
ADMIN_EMAIL="admin@example.com"
ADMIN_INITIAL_PASSWORD="CHANGE_ME_USE_A_UNIQUE_PASSWORD"
ADMIN_NAME="網站管理員"

# 每個值都應使用不同的密碼學安全亂數，至少 32 字元
MEMBER_AUTH_SECRET="CHANGE_ME_RANDOM_32_CHARS_MINIMUM"
COURSE_ACCESS_SECRET="CHANGE_ME_DIFFERENT_RANDOM_32_CHARS"
RATE_LIMIT_SECRET="CHANGE_ME_DIFFERENT_RANDOM_32_CHARS"
PUBLIC_REFERENCE_SECRET="CHANGE_ME_DIFFERENT_RANDOM_32_CHARS"
AUDIT_LOG_SECRET="CHANGE_ME_DIFFERENT_RANDOM_32_CHARS"

NEXT_PUBLIC_SITE_URL="http://localhost:3000"
EMAIL_PROVIDER=""
RESEND_API_KEY=""
EMAIL_FROM=""
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASSWORD=""
FACEBOOK_GROUP_URL=""

BANK_NAME=""
BANK_BRANCH=""
BANK_ACCOUNT_NAME=""
BANK_ACCOUNT_NUMBER=""
